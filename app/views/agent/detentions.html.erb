<% content_for :head_tags do %>
  <style>
    .agent-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 24px;
    }
    .agent-header h5 {
      font-family: 'Poppins', sans-serif;
      font-weight: 500;
      color: #33333C;
      margin: 0;
    }
    #search-btn {
      background-color: #EF4E50;
      font-family: 'Poppins', sans-serif;
      font-weight: 500;
      letter-spacing: 0.5px;
      border-radius: 4px;
      padding: 0 24px;
      height: 40px;
      line-height: 40px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
      border: none;
      color: #fff;
      font-size: 14px;
      transition: background 0.2s;
    }
    #search-btn:hover    { background-color: #d43e40; }
    #search-btn:disabled { background-color: #aaa; cursor: not-allowed; }
    #status-msg {
      font-family: 'Poppins', sans-serif;
      font-size: 13px;
      color: #888;
      margin-bottom: 16px;
      min-height: 20px;
    }
    .news-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 16px;
    }
    .news-card {
      background: #fff;
      border-radius: 8px;
      box-shadow: 0 1px 4px rgba(0,0,0,0.10);
      padding: 16px 18px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      transition: box-shadow 0.2s;
    }
    .news-card:hover { box-shadow: 0 3px 12px rgba(0,0,0,0.14); }
    .news-card .card-source {
      font-size: 11px;
      font-weight: 600;
      color: #EF4E50;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .news-card .card-date   { font-size: 11px; color: #aaa; }
    .news-card .card-title  {
      font-family: 'Poppins', sans-serif;
      font-size: 14px;
      font-weight: 500;
      color: #33333C;
      line-height: 1.4;
    }
    .news-card .card-snippet { font-size: 13px; color: #666; line-height: 1.5; }
    .news-card .card-link {
      font-size: 12px;
      color: #EF4E50;
      text-decoration: none;
      margin-top: auto;
      padding-top: 6px;
      display: inline-flex;
      align-items: center;
      gap: 4px;
    }
    .news-card .card-link:hover { text-decoration: underline; }
    .agent-spinner {
      display: inline-block;
      width: 16px;
      height: 16px;
      border: 2px solid #fff;
      border-top-color: transparent;
      border-radius: 50%;
      animation: agent-spin 0.7s linear infinite;
      vertical-align: middle;
    }
    @keyframes agent-spin { to { transform: rotate(360deg); } }
  </style>
<% end %>

<div class="b-inner-container" style="max-width: 1100px; margin: 0 auto; padding: 16px 8px;">
  <div class="agent-header">
    <h5>Agente de captura — Detenciones</h5>
    <button id="search-btn" data-search-url="<%= search_agent_detentions_path %>">
      <i class="material-icons" style="font-size:18px;">search</i>
      Buscar noticias del día
    </button>
  </div>

  <div id="status-msg"></div>
  <div id="results-grid" class="news-grid"></div>
</div>
