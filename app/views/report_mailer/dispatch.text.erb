<% type_label = case @briefing.report_type
               when 'briefing_semanal'
                 'briefing semanal'
               when 'reporte_riesgo'
                 'riesgo social'
               when 'reporte_conflictividad'
                 'violencia del crimen organizado'
               when 'reporte_prospectiva'
                 'prospectiva'
               else
                 'reporte'
               end %>

<% title = case @briefing.report_type
           when 'briefing_semanal'
             "Briefing Semanal #{@briefing.number.to_s.rjust(3, '0')}"
           when 'reporte_riesgo'
             "Riesgo Social"
           when 'reporte_conflictividad'
             "Violencia del Crimen Organizado"
           when 'reporte_prospectiva'
             "Prospectiva"
           else
             "Nuevo Reporte"
           end %>

<%= @greeting %>, <%= @user.member&.firstname || @user.mail %>

Te compartimos el <%= type_label %> de <%= @briefing.formatted_date %>:

<%= title %>

<%= @briefing.summary %>

<% if @download_url.present? %>
Descargar: <%= @download_url %>
<% end %>

---

Este correo fue enviado a <%= @user.mail %> porque tienes una suscripción activa con Lantia Intelligence.
© <%= Date.today.year %> Lantia Intelligence. Todos los derechos reservados.
